{
  "expo": {
    "name": "safe-trade",
    "slug": "safe-trade",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "safetrade",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.dagmills.safetrade",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [ "expo-router", [ "expo-splash-screen", { "image": "./assets/splash.png", "backgroundColor": "#000000", "resizeMode": "contain" } ] ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e31d812a-9889-4344-90ce-bee8dd244053"
      }
    }
  }
}
